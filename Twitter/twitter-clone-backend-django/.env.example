DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
DATABASE_URL=postgres://postgres:postgres@db:5432/twitter
REDIS_URL=redis://redis:6379/0

KAFKA_ENABLED=1
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TWEET_TOPIC=tweet-moderation-events
KAFKA_TWEET_GROUP_ID=tweet-moderation-consumer

MODERATION_DEDUP_TTL_SECONDS=86400

# Optional external NLP service endpoint.
# Expected response: {"is_ad_hominem": true|false, "confidence": 0.0-1.0}
AD_HOMINEM_MODEL_ENDPOINT=http://nlp-api:9000/predict
AD_HOMINEM_MODEL_TIMEOUT=15
